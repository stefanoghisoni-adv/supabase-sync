    "@remix-run/node": "^2.17.5",
    "@remix-run/react": "^2.17.5",
    "@remix-run/serve": "^2.17.5",
    "@shopify/polaris": "^13.9.5",
    "@shopify/shopify-app-remix": "^3.3.1",
    "@supabase/supabase-js": "^2.110.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "bullmq": "^5.80.1",
    "crypto-js": "^4.2.0",
    "dotenv": "^17.4.2",
    "ioredis": "^5.11.1",
    "isbot": "^5.2.0",
    "prisma": "^6.19.3",
