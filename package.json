{
  "name": "shopify-supabase-sync",
  "version": "1.0.0",
  "description": "Shopify app for syncing products and customers to merchant Supabase databases",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "shopify app dev",
    "build": "remix vite:build",
    "start": "remix-serve ./build/server/index.js",
